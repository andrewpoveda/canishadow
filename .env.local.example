# CanIShadow — environment (MIGRATION.md §7)
# Supabase keys are the ONLY required secrets. The app ships on $0:
# NPPES (search), US Census (geocode) and CARTO (map tiles) are all free/no-key.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Seed scripts ONLY (scripts/seed-demo.ts, scripts/seed-nppes.ts). Bypasses RLS.
# NEVER prefix with NEXT_PUBLIC and never import it client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — leave unset to run 100% free on NPPES. Only used when BOTH are set:
# SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=
